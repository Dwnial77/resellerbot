BOT_TOKEN=your_telegram_bot_token
ADMIN_TELEGRAM_IDS=123456789

# Panel #1 (seeded into DB on first run; add more panels via bot /panels)
XUI_BASE_URL=https://panel.example.com:2053
XUI_API_TOKEN=your_panel_api_token
# XUI_USERNAME=admin
# XUI_PASSWORD=your_password

# Public subscription base URL (subId is appended by the bot)
# Example: https://sub.example.com:2096/save/  ->  .../save/{subId}
XUI_SUB_PUBLIC_URL=https://sub.example.com:2096/save/

XUI_VERIFY_SSL=true
XUI_DEFAULT_INBOUND_IDS=1
# Auto-set flow=xtls-rprx-vision for VLESS+TCP+TLS/Reality inbounds
XUI_AUTO_VISION_FLOW=true
# Assign new clients to panel group {display_name}-{telegram_id}
XUI_AUTO_RESELLER_GROUP=true

DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

CREATE_RATE_LIMIT=5

# Refund reseller quota on service delete when actual traffic (up+down) is below this (GB)
QUOTA_REFUND_MAX_TRAFFIC_GB=1.0

# Usage alerts to resellers (80% / 90% of quota or client traffic)
USAGE_ALERT_ENABLED=false
USAGE_ALERT_INTERVAL_SECONDS=300

# Bot update via Telegram (admin uploads release ZIP)
UPDATE_ZIP_MAX_BYTES=52428800
SYSTEMD_SERVICE_NAME=resellerbot
ALLOW_UPDATE_DOWNGRADE=false

# Auto-update from GitHub Releases (public repo; no token required)
GITHUB_REPO=Dwnial77/resellerbot
GITHUB_UPDATE_ENABLED=true
